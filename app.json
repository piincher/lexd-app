{
  "expo": {
    "name": "ChinaLinkExpress",
    "slug": "ChinaLinkExpress",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/log.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splashscreen.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "@sentry/react-native/expo",
        {
          "organization": "nuvotech",
          "project": "chinalinkexpress",
          "url": "https://sentry.io/"
        }
      ],
      "expo-secure-store"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nuvotech.chinalinkexpress",
      "buildNumber": "9",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/log.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.nuvotech.chinalinkexpress",
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e4e59c47-9dfe-4dff-8b6d-7cf9a102486d"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e4e59c47-9dfe-4dff-8b6d-7cf9a102486d"
    }
  }
}
