{
  "expo": {
    "name": "ChinaLinkExpress",
    "slug": "ChinaLinkExpress",
    "version": "2.6.0",
    "jsEngine": "hermes",
    "orientation": "portrait",
    "icon": "./assets/images/log.png",
    "userInterfaceStyle": "light",
    "experiments": {
      "reactCompiler": true
    },
    "scheme": "chinalinkexpress",

    "splash": {
      "image": "./assets/images/splashscreen.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableBundleCompression": false,
            "extraProguardRules": "-keep public class com.horcrux.svg.** {*;}",
            "allowBackup": false
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "L'application accède à votre caméra pour vous permettre de prendre des photos et de les partager avec nous dans le chat."
        }
      ],
      "expo-web-browser",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "chinalinkexpress",
          "organization": "nuvotech"
        }
      ],
      "@sentry/react-native",
      [
        "expo-notifications",
        {
          "color": "#8B5CF6",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "assetBundlePatterns": [
      "assets/images/*",
      "assets/fonts/*",
      "assets/favicon.png"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nuvotech.chinalinkexpress",
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:chinalinkexpress.com",
        "applinks:www.chinalinkexpress.com"
      ],
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "itms-apps"
        ],
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/log.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "package": "com.nuvotech.chinalinkexpress",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "chinalinkexpress.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.chinalinkexpress.com",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "notification": {
        "color": "#8B5CF6",
        "androidMode": "default",
        "androidCollapsedTitle": "#{unread_notifications} nouvelles notifications"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e4e59c47-9dfe-4dff-8b6d-7cf9a102486d"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e4e59c47-9dfe-4dff-8b6d-7cf9a102486d"
    }
  }
}
