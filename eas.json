{
  "cli": {
    "version": ">= 9.0.7",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_VARIANT": "preview"
      }
    },
    "staging": {
      "distribution": "internal",
      "channel": "staging",
      "env": {
        "APP_ENV": "staging",
        "APP_VARIANT": "staging",
        "EXPO_PUBLIC_ENV": "staging",
        "EXPO_PUBLIC_API_URL": "https://api.lexdservices.com/api/v1",
        "EXPO_PUBLIC_API_URL_V2": "https://api.lexdservices.com/api/v2"
      },
      "ios": {
        "resourceClass": "m-medium",
        "buildConfiguration": "Release"
      },
      "android": {
        "resourceClass": "medium",
        "buildType": "apk"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.lexdservices.com/api/v1",
        "EXPO_PUBLIC_API_URL_V2": "https://api.lexdservices.com/api/v2"
      },
      "ios": {
        "resourceClass": "m-medium",
        "buildConfiguration": "Release"
      },
      "android": {
        "resourceClass": "medium",
        "buildType": "app-bundle"
      }
    },
    "production-device": {
      "distribution": "internal",
      "channel": "production",
      "env": {
        "APP_ENV": "production",
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.lexdservices.com/api/v1",
        "EXPO_PUBLIC_API_URL_V2": "https://api.lexdservices.com/api/v2"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "resourceClass": "m-medium",
        "buildConfiguration": "Release"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "contact@nuvotech.tech",
        "ascAppId": "6503253700",
        "appleTeamId": "CZCJLA5GHT"
      }
    }
  }
}
