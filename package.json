{
  "name": "homely",
  "version": "2.10.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:development": "node scripts/start-development.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:development": "npx eas-cli build --profile development",
    "build:production-device": "npx eas-cli build --profile production-device",
    "build:production": "npx eas-cli build --profile production",
    "test": "jest --watch",
    "test:ci": "jest --ci --runInBand --coverage",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "eas-build-pre-install": "npm config set legacy-peer-deps true",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "sentry:upload-sourcemaps": "sentry-expo-upload-sourcemaps dist",
    "analyze:bundle": "npx react-native-bundle-visualizer",
    "analyze:expo": "node scripts/analyze-bundle-expo.js",
    "check:bundle": "node scripts/check-bundle-size.js",
    "bump-version": "node scripts/bump-version.js"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "npx eslint --fix"
  },
